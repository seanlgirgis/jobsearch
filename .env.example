# Copy this file to `.env` and set your real keys locally (never commit `.env`).

# Provider switch: openai or xai
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_LIGHT_MODEL=gpt-5.4-nano
OPENAI_HEAVY_MODEL=gpt-5.4-mini

# xAI / Grok fallback
XAI_API_KEY=replace_with_your_grok_api_key
GROK_LIGHT_MODEL=grok-3-mini
GROK_HEAVY_MODEL=grok-3
